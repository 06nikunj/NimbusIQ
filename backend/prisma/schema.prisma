generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- USER TABLE ----
// Stores every person who registers on NimbusIQ
model User {
  id               Int              @id @default(autoincrement())
  name             String
  email            String           @unique
  password         String           // bcrypt hashed, never plain text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations — one user has one credentials record and many alerts
  awsCredentials   AwsCredentials?
  alerts           Alert[]
  alertHistories   AlertHistory[]
  aiRecommendations AiRecommendation[]
}

// ---- AWS CREDENTIALS TABLE ----
// Stores each user's AWS keys — encrypted before saving
model AwsCredentials {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique  // one set of credentials per user
  accessKeyId      String            // encrypted
  secretAccessKey  String            // encrypted
  region           String   @default("ap-south-1")
  isVerified       Boolean  @default(false)  // true after test connection passes
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relation back to user
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---- ALERT TABLE ----
// Budget limits set by each user
model Alert {
  id               Int      @id @default(autoincrement())
  userId           Int
  dailyLimit       Float
  monthlyLimit     Float
  email            String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---- COST SNAPSHOT TABLE ----
// Daily cost data pulled from AWS Cost Explorer
model CostSnapshot {
  id               Int      @id @default(autoincrement())
  userId           Int
  date             String
  amount           Float
  service          String
  region           String
  createdAt        DateTime @default(now())
}

// ---- AI RECOMMENDATION TABLE ----
// Recommendations generated by OpenAI for each user
model AiRecommendation {
  id               Int      @id @default(autoincrement())
  userId           Int
  resource         String
  recommendation   String
  saving           Float
  status           String   @default("pending")
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---- ALERT HISTORY TABLE ----
// Log of every time a budget alert was triggered
model AlertHistory {
  id               Int      @id @default(autoincrement())
  userId           Int
  type             String
  amount           Float
  limit            Float
  triggeredAt      DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}